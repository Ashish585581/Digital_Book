# BookLore Backend Environment Configuration

# Application
APP_NAME=BookLore
APP_ENV=development
APP_DEBUG=true
BOOKLORE_PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://booklore:devpassword@localhost:5432/booklore

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
# Generate a secure key with: openssl rand -hex 32
JWT_SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage
UPLOAD_DIR=/data/books
MAX_FILE_SIZE=500000000
COVER_DIR=/data/covers
MAX_COVER_SIZE=5000000

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000